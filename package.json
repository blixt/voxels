{
  "name": "voxels",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "build": "bun run scripts/build.ts",
    "start": "NODE_ENV=production bun run scripts/start.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun test",
    "test:lod-lab": "bun test tests/lod-debug-world.test.ts tests/lod-handoff.test.ts tests/frame-timing-buckets.test.ts",
    "versions": "bun run scripts/check-versions.ts",
    "profile": "bun run scripts/profile-scenes.ts",
    "profile:stream": "bun run scripts/profile-procedural-stream.ts",
    "profile:game-stream": "bun run scripts/profile-game-stream.ts",
    "profile:lod-residency": "bun run scripts/profile-lod-residency.ts",
    "profile:lod-cache": "bun run scripts/profile-lod-cache-reuse.ts",
    "atlas:routes": "bun run scripts/route-atlas.ts",
    "atlas:views": "bun run scripts/capture-view-atlas.ts",
    "lab:object": "bun run scripts/object-lab.ts",
    "lab:shader": "bun run scripts/shader-smoke-lab.ts",
    "lab:terrain": "bun run scripts/terrain-surface-lab.ts",
    "verify:smoke": "bun run scripts/verify-smoke.ts",
    "verify:render": "bun run scripts/run-render-verification.ts",
    "verify:rpg": "bun run scripts/run-voxel-rpg-verification.ts",
    "audit:rpg-slice": "bun run scripts/rpg-slice-audit.ts",
    "analyze:trace": "bun run scripts/analyze-chrome-trace.ts",
    "analyze:screenshot": "bun run scripts/analyze-screenshot-composition.ts",
    "cycle:bench": "bun run scripts/run-cycle-bench.ts",
    "trace:route": "bun run scripts/run-browser-route-trace.ts",
    "bench:browser-game": "bun run scripts/run-browser-game-benchmarks.ts",
    "bench:lod-persistence": "bun run scripts/run-browser-game-benchmarks.ts --startup-warmup=0 --startup-iterations=0 --walk-warmup=0 --walk-iterations=0 --lod-persistence-iterations=1",
    "lab:browser": "bun run scripts/owned-browser-lab.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@webgpu/types": "0.1.69",
    "typescript": "5.9.3"
  }
}
