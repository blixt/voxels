{
  "name": "voxels",
  "version": "0.2.0",
  "private": true,
  "description": "A Rust-first procedural voxel world rendered with WebGPU",
  "type": "module",
  "scripts": {
    "build:wasm": "node scripts/build-wasm.ts --release"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "~6.0.2",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.9.0",
      "onFail": "download"
    },
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  }
}
