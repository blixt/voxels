{
  "name": "voxels",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/server.ts",
    "build": "bun run scripts/build.ts",
    "start": "NODE_ENV=production bun run scripts/start.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun test",
    "versions": "bun run scripts/check-versions.ts",
    "profile": "bun run scripts/profile-scenes.ts",
    "profile:stream": "bun run scripts/profile-procedural-stream.ts",
    "profile:game-stream": "bun run scripts/profile-game-stream.ts",
    "analyze:trace": "bun run scripts/analyze-chrome-trace.ts",
    "cycle:bench": "bun run scripts/run-cycle-bench.ts",
    "trace:route": "bun run scripts/run-browser-route-trace.ts",
    "bench:browser-game": "bun run scripts/run-browser-game-benchmarks.ts"
  },
  "devDependencies": {
    "@types/bun": "1.3.10",
    "@webgpu/types": "0.1.69",
    "typescript": "5.9.3"
  }
}
